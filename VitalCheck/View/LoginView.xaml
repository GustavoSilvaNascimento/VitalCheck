<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VitalCheck.View.LoginView">

    <VerticalStackLayout VerticalOptions="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackLayout
                Grid.Row="0"
                HorizontalOptions="Center"
                Margin="0,0,0,60">

                <Label
                    Text="Login"
                    FontFamily="DMSans"
                    TextColor="{StaticResource Saude4}"
                    FontSize="30"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>

                <Label
                    Text="Por favor, insira seus dados"
                    FontSize="13"
                    FontFamily="DMSans"
                    HorizontalOptions="Center"/>

                <!-- Formulário -->
                <StackLayout
                    Orientation="Vertical"
                    HorizontalOptions="Center"
                    Margin="0,70,0,70">

                    <Label
                        Text="Email"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="exemplo@gmail.com"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Keyboard="Email"
                        Text="{Binding Email}" />

                    <Label
                        Text="Senha"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="Mínimo de 8 caracteres"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        IsPassword="True"
                        Text="{Binding Senha}" />

                </StackLayout>

                <!-- Botões -->
                <VerticalStackLayout
                    Spacing="8"
                    HorizontalOptions="Center">

                    <Button
                        Text="Login"
                        BackgroundColor="{StaticResource Saude4}"
                        TextColor="White"
                        WidthRequest="210"
                        CornerRadius="20"
                        Command="{Binding LoginCommand}" />

                    <Label
                        Text="Não tem uma conta? Cadastre-se!"
                        FontSize="10"
                        FontFamily="DMSans"
                        HorizontalOptions="Center"/>

                    <Button
                        Text="Cadastrar"
                        BackgroundColor="{StaticResource Saude2}"
                        TextColor="{StaticResource Saude1}"
                        WidthRequest="210"
                        CornerRadius="20"
                        Command="{Binding CadastroCommand}" />

                </VerticalStackLayout>

            </StackLayout>

        </Grid>

    </VerticalStackLayout>
</ContentPage>