<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VitalCheck.View.LoginView">

    <VerticalStackLayout VerticalOptions="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <StackLayout 
                Grid.Row="0"
                Orientation="Vertical"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <!-- Título -->
                <Label 
                    Text="Bem-Vindo" 
                    FontSize="24" 
                    FontAttributes="Bold" 
                    HorizontalOptions="Center" 
                    VerticalOptions="Start" />

                <Label 
                    Text="Por favor, insira seus dados:" 
                    FontSize="10" 
                    HorizontalOptions="Center" 
                    VerticalOptions="Center" />

                <!-- Email -->
                <Label 
                    Text="Email:" 
                    FontSize="12" 
                    FontAttributes="Bold" 
                    HorizontalOptions="Start" 
                    Margin="0,20,0,0" />

                <Entry 
                    x:Name="EmailEntry" 
                    Placeholder="Email" 
                    WidthRequest="250" 
                    Margin="0,2" />

                <!-- Senha -->
                <Label 
                    Text="Senha:" 
                    FontSize="12" 
                    FontAttributes="Bold" 
                    HorizontalOptions="Start" 
                    Margin="0,2" />

                <Entry 
                    x:Name="SenhaEntry" 
                    Placeholder="Senha" 
                    IsPassword="True" 
                    WidthRequest="250" 
                    Margin="0,2" />

                <!-- Botão Login -->
                <Button 
                    Text="Login" 
                    BackgroundColor="{StaticResource Saude4}"
                    WidthRequest="120" 
                    Margin="0,20,0,0"
                    Clicked="OnLoginClicked"
                    />

                <!-- Cadastro -->
                <Label 
                    Text="Não tem uma conta? Cadastre-se!" 
                    FontSize="10" 
                    HorizontalOptions="Center" 
                    VerticalOptions="Center"
                    Margin="0,2" />

                <Button 
                    Text="Cadastrar" 
                    WidthRequest="120"
                    BackgroundColor="{StaticResource Saude2}"
                    Margin="0,10"
                    Clicked="OnCadastroClicked" />

            </StackLayout>

        </Grid>

    </VerticalStackLayout>

</ContentPage>