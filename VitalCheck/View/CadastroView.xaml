<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
    x:Class="VitalCheck.View.CadastroView">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <!-- Título -->
                <StackLayout 
                    Grid.Row="0" 
                    Orientation="Vertical" 
                    HorizontalOptions="Center" 
                    VerticalOptions="End"
                    Margin="0,0,0,60">

                    <Label 
                        Text="Bem-vindo!"
                        FontFamily="DMSans"
                        TextColor="{StaticResource Saude4}"
                        FontSize="30" 
                        FontAttributes="Bold" 
                        HorizontalOptions="Center" 
                        VerticalOptions="Start" />

                    <Label 
                        Text="Por favor, insira seus dados:" 
                        FontSize="13"
                        FontFamily="DMSans"
                        HorizontalOptions="Center" 
                        VerticalOptions="Center" />

                </StackLayout>

                <!-- Formulário -->
                <StackLayout 
                    Grid.Row="1" 
                    Orientation="Vertical" 
                    HorizontalOptions="Center" 
                    VerticalOptions="End"
                    Margin="0,0,0,30">

                    <Label 
                        Text="Nome"
                        FontFamily="DMSans"
                        FontSize="13" 
                        TextColor="{StaticResource Saude4}"
                        HorizontalOptions="Start" 
                        Margin="0,2" />

                    <Entry 
                        x:Name="NomeCompletoEntry" 
                        Placeholder="ex: José da Silva" 
                        FontFamily="DMSans"
                        WidthRequest="250" 
                        Margin="0,6" />

                    <Label 
                        Text="Email"
                        FontFamily="DMSans"
                        FontSize="13" 
                        TextColor="{StaticResource Saude4}"
                        HorizontalOptions="Start" 
                        Margin="0,6" />

                    <Entry 
                        x:Name="EmailEntry" 
                        Placeholder="exemplo@gmail.com" 
                        WidthRequest="250" 
                        FontFamily="DMSans"
                        Margin="0,6" />

                    <Label 
                        Text="Senha"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}"
                        HorizontalOptions="Start" 
                        Margin="0,6" />

                    <Entry 
                        x:Name="SenhaEntry" 
                        Placeholder="Mínimo de 8 caracteres" 
                        IsPassword="True" 
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Margin="0,6" />

                    <Label 
                        Text="Confirmar senha"
                        FontFamily="DMSans"
                        FontSize="13" 
                        TextColor="{StaticResource Saude4}"
                        HorizontalOptions="Start" 
                        Margin="0,6" />

                    <Entry 
                        x:Name="ConfirmarSenhaEntry" 
                        Placeholder="Repita sua senha" 
                        IsPassword="True" 
                        WidthRequest="250" 
                        FontFamily="DMSans"
                        Margin="0,2" />

                </StackLayout>

                <!-- Botões -->
                <VerticalStackLayout 
                    Grid.Row="2" 
                    Spacing="8" 
                    HorizontalOptions="Center" 
                    VerticalOptions="Center">

                    <Button 
                        Text="Cadastrar" 
                        BackgroundColor="{StaticResource Saude4}" 
                        TextColor="White"
                        FontFamily="DMSans"
                        WidthRequest="210"
                        CornerRadius="20"
                        Margin="0,10,0,6" 
                        Clicked="OnCadastrarClicked" />

                    <Label 
                        Text="Você já tem uma conta?" 
                        FontSize="10" 
                        HorizontalOptions="Center" 
                        Margin="0,2" />

                    <Button 
                        Text="Login" 
                        BackgroundColor="{StaticResource Saude2}" 
                        TextColor="{StaticResource Saude1}" 
                        FontFamily="DMSans"
                        WidthRequest="210"
                        CornerRadius="20"
                        Clicked="OnLoginClicked" 
                        Margin="0,4" />

                </VerticalStackLayout>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>