<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VitalCheck.View.CadastroView">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <StackLayout
                    Grid.Row="0"
                    HorizontalOptions="Center"
                    Margin="0,0,0,60">

                    <Label
                        Text="Bem-vindo!"
                        FontFamily="DMSansBold"
                        TextColor="{StaticResource Saude4}"
                        FontSize="30"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="Por favor, insira seus dados:"
                        FontSize="13"
                        FontFamily="DMSans"
                        HorizontalOptions="Center"/>

                </StackLayout>

                <!-- Formulário -->
                <StackLayout
                    Grid.Row="1"
                    HorizontalOptions="Center"
                    Margin="0,0,0,30">

                    <Label
                        Text="Nome"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="ex: José da Silva"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Text="{Binding Nome}" />

                    <Label
                        Text="Email"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="exemplo@gmail.com"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Keyboard="Email"
                        Text="{Binding Email}" />

                    <Label
                        Text="Senha"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="Mínimo de 8 caracteres"
                        IsPassword="True"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Text="{Binding Senha}" />

                    <Label
                        Text="Confirmar senha"
                        FontFamily="DMSans"
                        FontSize="13"
                        TextColor="{StaticResource Saude4}" />

                    <Entry
                        Placeholder="Repita sua senha"
                        IsPassword="True"
                        WidthRequest="250"
                        FontFamily="DMSans"
                        Text="{Binding ConfirmarSenha}" />

                </StackLayout>

                <!-- Botões -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Spacing="8"
                    HorizontalOptions="Center">

                    <Button
                        Text="Cadastrar"
                        BackgroundColor="{StaticResource Saude4}"
                        TextColor="White"
                        FontFamily="DMSans"
                        WidthRequest="210"
                        CornerRadius="20"
                        Margin="0,10,0,6"
                        Command="{Binding CadastrarCommand}" />

                    <Label
                        Text="Você já tem uma conta?"
                        FontSize="10"
                        HorizontalOptions="Center" />

                    <Button
                        Text="Login"
                        BackgroundColor="{StaticResource Saude2}"
                        TextColor="{StaticResource Saude1}"
                        FontFamily="DMSans"
                        WidthRequest="210"
                        CornerRadius="20"
                        Margin="0,4"
                        Command="{Binding LoginCommand}" />

                </VerticalStackLayout>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>