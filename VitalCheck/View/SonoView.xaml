<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.SonoView">
    
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0"
                 Source="left.png"
                 WidthRequest="0"
                 HeightRequest="0"
                 Aspect="AspectFill"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="0,10"
                 Clicked="ImageButton_Clicked"/>

                <Label Grid.Row="0"
                Text="Seu sono"
                FontFamily="DMSans"
                TextColor="{StaticResource Saude4}"
                FontSize="20"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                Margin="0,70"/>
                
                <!--Inserir score de acordo com o sono colocado no check in
                    //aqui
                -->
                
            </Grid>

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,-40,0,20">
                <Label x:Name="ScoreLabelSono"
                        Text="8h"
                        FontFamily="DMSansBold"
                        FontSize="60"
                        TextColor="{StaticResource Saude4}"
                        HorizontalOptions="Center"
                />

                <Label Text="Hoje"
                       FontSize="16"
                       FontFamily="DMSans"
                       TextColor="{StaticResource Saude4}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Margin="0,20,0,0" Spacing="6">
                <Grid RowDefinitions="*, *, *">
                    <Label Grid.Row="0"
                       Text="Histórico de Sono"
                       FontFamily="DMSans"
                       TextColor="{StaticResource Saude4}"
                       FontSize="20"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Margin="0,10"/>

                    <Border Grid.Row="1"
                        Stroke="#2A3B5C" 
                        StrokeThickness="1"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 12"
                        HeightRequest="80"
                        Padding="15">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label x:Name="DiaLabel" Text="DIA" FontSize="11" FontFamily="DMSansBold" TextColor="#8A9BAE"/>
                            <Label x:Name="SonoLabel" Text="7h " FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                        Stroke="#2A3B5C" 
                        StrokeThickness="1"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 12"
                        HeightRequest="80"
                        Margin="0,10"
                        Padding="15">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label x:Name="DiaLabel2" Text="DIA" FontSize="11" FontFamily="DMSansBold" TextColor="#8A9BAE"/>
                            <Label x:Name="SonoLabel2" Text="7h " FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>