<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.AdicionarRefeicaoModal"
             Title="Adicionar Refeição"
             BackgroundColor="#80000000">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="8" VerticalOptions="Center" BackgroundColor="White" Margin="30">
            <Label Text="Nome da Refeição:" FontSize="14" FontFamily="DMSans"/>
            <Entry x:Name="NomeRefeicaoEntry" Placeholder="ex.: Almoço, jantar, lanche..."/>

            <Label Text="Calorias:" FontSize="14" FontFamily="DMSans"/>
            <Entry x:Name="CaloriasEntry" Placeholder="ex.: 2400 (Apenas números)"/>

            <Button Text="Salvar" Clicked="Salvar_Clicked" TextColor="White" FontFamily="DMSansSemiBold"/>
            <Button Text="Cancelar" Clicked="Cancelar_Clicked" BackgroundColor="{StaticResource Saude1}" TextColor="Black" FontFamily="DMSansSemiBold"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>