<?xml version="1.0" encoding="utf-8" ?>
    
<!--Instalar pacote NuGet SkiaSharp.Extended.UI.Maui antes de compilar para o bom funcionamento das animações-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="VitalCheck.View.DashboardView">
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            
            <!--Header-->
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0" Source="avatar.png"
                         WidthRequest="30"
                         HeightRequest="30"
                         Aspect="AspectFill"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         Margin="0,10"
                         />
                <Label Grid.Row="0" Text="Olá, Fulano" 
                        FontFamily="DMSans"
                        TextColor="{StaticResource Saude4}"
                        FontSize="18" 
                        HorizontalOptions="Start" 
                        VerticalOptions="Center"
                        Margin="60,0"/>
            </Grid>
            
            <!--Dia + Animação progresso vitalscore-->
            <Grid RowDefinitions="auto" Margin="0,20">
                <Label Text="Hoje"
                       FontFamily="DMSansSemiBold"
                       TextColor="{StaticResource Saude4}"
                       FontSize="30"
                       HorizontalOptions="Start"/>

                <!--Adicionar lógica do vitalscore aqui, para que a animação trave no frame respectivo ao score-->
                <skia:SKLottieView x:Name="LottieVital"  Source="progress.json"
                                   RepeatCount="-1"
                                   IsAnimationEnabled="False"
                                   Progress="0"
                                   HeightRequest="200"
                                   WidthRequest="200"
                                   HorizontalOptions="Center"
                                   Margin="60"/>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="ScoreLabel"
                           Text="85"
                           FontFamily="DMSansBold"
                           FontSize="50"
                           TextColor="{StaticResource Saude4}"
                           HorizontalOptions="Center"
                           />

                    <Label Text="VitalScore"
                           FontSize="16"
                           FontFamily="DMSans"
                           TextColor="{StaticResource Saude4}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Grid RowDefinitions="auto">
                <Label 
                    Text="Realize seu check-in diário!" 
                    FontSize="14" 
                    FontFamily="DMSans"
                    HorizontalOptions="Center" 
                    Margin="0,-20"
                    TextColor="{StaticResource Saude4}"/>
                <Button 
                    Text="Check-In" 
                    BackgroundColor="{StaticResource Saude4}" 
                    TextColor="White"
                    FontFamily="DMSans"
                    WidthRequest="210"
                    CornerRadius="20"
                    Margin="0,10,0,6"/>
            </Grid>

            <Grid RowDefinitions="auto" Margin="0,40">
                <Label Text="Seu último check-in"
                   FontFamily="DMSansSemiBold"
                   TextColor="{StaticResource Saude4}"
                   FontSize="25"
                   HorizontalOptions="Start"/>
                
                <!--Informações do último check-in-->
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>