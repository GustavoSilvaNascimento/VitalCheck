<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.DashboardView">
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            
            <!--Header-->
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0" Source="avatar.png"
                         WidthRequest="30"
                         HeightRequest="30"
                         Aspect="AspectFill"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         Margin="0,10"
                         />
                <Label Grid.Row="0" Text="Olá, Fulano" 
                    FontFamily="DMSans"
                    TextColor="{StaticResource Saude4}"
                    FontSize="18" 
                    HorizontalOptions="Start" 
                    VerticalOptions="Center"
                    Margin="60,0"/>
            </Grid>

            <Grid RowDefinitions="auto" Margin="0,20">
                <Label Text="Hoje"
                       FontFamily="DMSans"
                       TextColor="{StaticResource Saude4}"
                       FontSize="30"
                       HorizontalOptions="Start"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>