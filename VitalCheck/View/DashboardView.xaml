<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.DashboardView">
    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="28,16,28,100" Spacing="0">
                
                <!--Header-->
                <Grid RowDefinitions="auto, *, auto" Margin="0,10,0,0">
                    <Border Grid.Column="0"
                            WidthRequest="36" HeightRequest="36"
                            StrokeShape="Ellipse"
                            HorizontalOptions="Start"
                            Stroke="Transparent"
                            BackgroundColor="#D8E8F5">
                        <Image Source="avatar.png"
                               Aspect="AspectFill"
                               WidthRequest="36"
                               HeightRequest="36"/>
                    </Border>
                    
                    <Label Grid.Row="1" Text="Olá, Fulano" 
                            FontFamily="DMSans"
                            TextColor="{StaticResource Saude4}"
                            FontSize="16" 
                            VerticalOptions="Center"
                            Margin="50,-36,0,0"/>
                </Grid>
                
                <!--Dia + Animação progresso vitalscore-->
                    <Label Text="Hoje"
                           FontFamily="DMSansSemiBold"
                           TextColor="{StaticResource Saude4}"
                           FontSize="24"
                           HorizontalOptions="Start"
                           Margin="0,25"/>

                    <!--Adicionar lógica do vitalscore aqui junto com alguma animacao para que o label e a animacao sejam de acordo com o score-->

                <VerticalStackLayout HorizontalOptions="Center" Margin="0,0,0,0">
                    <Label x:Name="ScoreLabel"
                               Text="85"
                               FontFamily="DMSansBold"
                               FontSize="60"
                               TextColor="{StaticResource Saude4}"
                               HorizontalOptions="Center"
                               />

                    <Label Text="VitalScore"
                               FontSize="16"
                               FontFamily="DMSans"
                               TextColor="{StaticResource Saude4}"
                               HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Margin="0,20,0,0" Spacing="6">
                    <Label
                        x:Name="ProgressLabel"
                        Text="Quase lá!" 
                        FontSize="13" 
                        FontFamily="DMSans"
                        TextColor="{StaticResource Saude4}"/>

                    <Grid HeightRequest="8">
                        <Border StrokeShape="RoundRectangle 4"
                                BackgroundColor="#C9D8EA"
                                HeightRequest="8"/>

                        <Border x:Name="ProgressFill"
                                StrokeShape="RoundRectangle 4"
                                BackgroundColor="#1A2E6C"
                                HeightRequest="8"
                                HorizontalOptions="Start"
                                WidthRequest="240"/>
                        <!-- ajuste WidthRequest via code-behind com base no score -->
                    </Grid>
                </VerticalStackLayout>
                <Label Text="Seu último check-in"
                       FontFamily="DMSansSemiBold"
                       TextColor="{StaticResource Saude4}"
                       FontSize="22"
                       Margin="0,24,0,0"/>

                <Label Text="Ontem"
                       FontFamily="DMSansSemiBold"
                       TextColor="{StaticResource Saude4}"
                       FontSize="14"
                       Opacity="0.7"
                       Margin="0,2,0,12"/>

                <VerticalStackLayout x:Name="CheckInContent" Spacing="15">
                    <!--Energia-->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                        <Border Grid.Column="0"
                                Stroke="#2A3B5C" 
                                StrokeThickness="1"
                                BackgroundColor="Transparent"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="80"
                                Padding="15">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="ENERGIA" FontSize="11" TextColor="#8A9BAE" FontFamily="DMSansBold"/>
                                <Label x:Name="EnergiaLabel" Text="-" FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                            </VerticalStackLayout>
                        </Border>
                    

                    <!--Sono-->
                    <Border Grid.Column="1"
                            Stroke="#2A3B5C" 
                            StrokeThickness="1"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="80"
                            Padding="15">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label Text="SONO" FontSize="11" FontFamily="DMSansBold" TextColor="#8A9BAE"/>
                                <Label x:Name="SonoLabel" Text="- h" FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                        </VerticalStackLayout>
                    </Border>

                    </Grid>

                    <!--Humor-->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,0">
                        <Border Grid.Column="0"
                            Stroke="#2A3B5C" 
                            StrokeThickness="1"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="80"
                            Padding="15"
                            Margin="0,3">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="HUMOR" FontSize="11" FontFamily="DMSansBold" TextColor="#8A9BAE"/>
                                <Label x:Name="HumorLabel" Text="-" FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!--Treino-->
                        <Border Grid.Column="1"
                            Stroke="#2A3B5C" 
                            StrokeThickness="1"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="80"
                            Padding="15">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="TREINO" FontSize="11" FontFamily="DMSansBold" TextColor="#8A9BAE"/>
                                <Label x:Name="TreinoLabel" Text="-" FontSize="20" FontFamily="DMSansBold" TextColor="{StaticResource Saude4}"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>
                
                <!--ESTADO SEM CHECK IN-->
                <VerticalStackLayout x:Name="EmptyCheckIn"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Margin="0,16,0,0">
                    <Label Text="Nenhum check-in ainda."
                           FontFamily="DMSans"
                           FontSize="15"
                           TextColor="#1A2E6C"
                           Opacity="0.5"
                           HorizontalOptions="Center"/>
                    <Label Text="Complete seu primeiro check-in hoje!"
                           FontFamily="DMSans"
                           FontSize="13"
                           TextColor="#1A2E6C"
                           Opacity="0.4"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
            
        </ScrollView>

        <ImageButton Source="botaoa_adicionar.png"
                     WidthRequest="30"
                     HeightRequest="30"
                     CornerRadius="30"
                     Aspect="AspectFit"
                     HorizontalOptions="Center"
                     VerticalOptions="End"
                     Margin="0,30"
                     Clicked="ImageButton_Clicked"/>

    </Grid>

</ContentPage>