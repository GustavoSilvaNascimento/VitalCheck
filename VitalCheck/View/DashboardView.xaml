<?xml version="1.0" encoding="utf-8" ?>
    
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.DashboardView">
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            
            <!--Header-->
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0" Source="avatar.png"
                         WidthRequest="30"
                         HeightRequest="30"
                         Aspect="AspectFill"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         Margin="0,10"
                         />
                <Label Grid.Row="0" Text="Olá, Fulano" 
                        FontFamily="DMSans"
                        TextColor="{StaticResource Saude4}"
                        FontSize="18" 
                        HorizontalOptions="Start" 
                        VerticalOptions="Center"
                        Margin="60,0"/>
            </Grid>
            
            <!--Dia + Animação progresso vitalscore-->
            <Grid RowDefinitions="auto" Margin="0,20">
                <Label Text="Hoje"
                       FontFamily="DMSansSemiBold"
                       TextColor="{StaticResource Saude4}"
                       FontSize="30"
                       HorizontalOptions="Start"/>

                <!--Adicionar lógica do vitalscore aqui junto com alguma animacao para que o label e a animacao sejam de acordo com o score-->
                
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="ScoreLabel"
                           Text="85"
                           FontFamily="DMSansBold"
                           FontSize="50"
                           TextColor="{StaticResource Saude4}"
                           HorizontalOptions="Center"
                           />

                    <Label Text="VitalScore"
                           FontSize="16"
                           FontFamily="DMSans"
                           TextColor="{StaticResource Saude4}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Grid RowDefinitions="auto">
                <Label 
                    Text="Já realizou seu check-in diário hoje?" 
                    FontSize="14" 
                    FontFamily="DMSans"
                    HorizontalOptions="Center" 
                    Margin="0,-20"
                    TextColor="{StaticResource Saude4}"/>

            </Grid>

            <Grid RowDefinitions="auto" Margin="0,40">
                <Label Text="Seu último check-in"
                   FontFamily="DMSansSemiBold"
                   TextColor="{StaticResource Saude4}"
                   FontSize="25"
                   HorizontalOptions="Start"/>
                
                <!--Informações do último check-in-->
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>