<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VitalCheck.MainPage">

    <Grid>

        <!-- Conteúdo rolável -->
        <ScrollView>
            <VerticalStackLayout Padding="0, 40, 0, 0">

                <!-- Imagem -->

                <Image
                    Source="mainpageimg.png"
                    HeightRequest="370"
                    Margin="0,0,0,40"/>

                <!-- Texto -->

                <Label 
                    Text=" Bem-vindo ao&#10; seu rastreador de&#10; saude pessoal"
                    TextColor="{StaticResource Saude4}"
                    FontFamily="DMSansBold"
                    FontSize="29"
                    LineHeight="1.1"
                    HorizontalOptions="Start"
                    Margin="30,0,30,0" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Botão flutuante -->
        <ImageButton 
            Source="seta_direita_figma.png"
            WidthRequest="45"
            HeightRequest="45"
            CornerRadius="90"
            Aspect="AspectFit"
            BackgroundColor="{StaticResource Saude4}"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="20"
            Clicked="OnSetaClicked" />

    </Grid>

</ContentPage>