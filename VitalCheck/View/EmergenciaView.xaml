<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.EmergenciaView"
             Title="EmergenciaView">
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0"
             Source="left.png"
             WidthRequest="0"
             HeightRequest="0"
             Aspect="AspectFill"
             HorizontalOptions="Start"
             VerticalOptions="Start"
             Margin="0,10"
             Clicked="ImageButton_Clicked_1"/>

                <Label Grid.Row="0"
            Text="Seu botão de emergência"
            FontFamily="DMSans"
            TextColor="{StaticResource Saude4}"
            FontSize="20"
            HorizontalOptions="Start"
            VerticalOptions="Center"
            Margin="0,70"/>

                <Button
            Text="Emergência"
            BackgroundColor="Red"
            TextColor="White"
            FontFamily="DMSans"
            WidthRequest="210"
            CornerRadius="20"
            Margin="0,10,0,6"
            Clicked="Button_Clicked"/>

            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>