<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCheck.View.AlimentacaoView"
             >
    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,100" Spacing="0">
            
            <Grid RowDefinitions="auto">
                <ImageButton Grid.Row="0"
                             Source="left.png"
                             WidthRequest="15"
                             HeightRequest="15"
                             Aspect="AspectFill"
                             HorizontalOptions="Start"
                             VerticalOptions="Start"
                             Margin="0,10"
                             Clicked="ImageButton_Clicked"/>

                <Label Grid.Row="0"
                       Text="Resumo Alimentar"
                       FontFamily="DMSans"
                       TextColor="{StaticResource Saude4}"
                       FontSize="18"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Margin="60,0"/>
            </Grid>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>